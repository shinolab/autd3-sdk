---
interface Props {
  kind?: "sine" | "square" | "radiation";
  freq?: number;
  sampling?: number;
  fixed?: string;
}
const { kind = "sine", freq = 200, sampling, fixed } = Astro.props;
const fs = sampling ?? freq * 20;
const config = JSON.stringify({ kind, freq, sampling: fs });
const fixedText = fixed ?? `freq = ${freq} Hz`;
---

<div class="autd-mod" data-config={config}>
  <canvas class="autd-mod-canvas"></canvas>
  <div class="autd-mod-controls">
      <div class="autd-mod-fixed">{fixedText}</div>
  </div>
</div>

<script>
  type Cfg = Record<string, number> & { kind: string; freq: number; sampling: number };

  interface Spec {
    key: string;
    label: string;
    type?: "range" | "toggle";
    unit?: string;
    min?: number;
    max?: number;
    step?: number;
    def: number;
  }

  const SPECS: Record<string, Spec[]> = {
    sine: [
      { key: "sampling", label: "sampling_config", unit: "Hz", def: 0 },
      { key: "amplitude", label: "amplitude", min: 0, max: 255, step: 1, def: 255 },
      { key: "offset", label: "offset", min: 0, max: 255, step: 1, def: 128 },
      { key: "phase", label: "phase", unit: "°", min: 0, max: 360, step: 1, def: 0 },
    ],
    square: [
      { key: "sampling", label: "sampling_config", unit: "Hz", def: 0 },
      { key: "high", label: "high", min: 0, max: 255, step: 1, def: 255 },
      { key: "low", label: "low", min: 0, max: 255, step: 1, def: 0 },
      { key: "duty", label: "duty", min: 0, max: 1, step: 0.05, def: 0.5 },
    ],
    radiation: [
      { key: "radiation", label: "radiation_pressure", type: "toggle", def: 1 },
    ],
  };

  const clampByte = (v: number) => Math.max(0, Math.min(255, Math.round(v)));

  function valueFn(c: Cfg): (t: number) => number {
    if (c.kind === "square") {
      return (t) => {
        const frac = (((t * c.freq) % 1) + 1) % 1;
        return frac < c.duty ? c.high : c.low;
      };
    }
    if (c.kind === "radiation") {
      return (t) => {
        const raw = clampByte(128 + 127.5 * Math.sin(2 * Math.PI * c.freq * t));
        return c.radiation ? Math.round(255 * Math.sqrt(raw / 255)) : raw;
      };
    }
    // sine
    return (t) =>
      clampByte(
        c.offset +
          (c.amplitude / 2) *
            Math.sin(2 * Math.PI * c.freq * t + (c.phase * Math.PI) / 180),
      );
  }

  function refFn(c: Cfg): ((t: number) => number) | null {
    if (c.kind !== "radiation") return null;
    return (t) => clampByte(128 + 127.5 * Math.sin(2 * Math.PI * c.freq * t));
  }

  function draw(canvas: HTMLCanvasElement, c: Cfg) {
    const ctx = canvas.getContext("2d")!;
    const dpr = Math.min(window.devicePixelRatio, 2);
    const cssW = canvas.clientWidth || 600;
    const cssH = canvas.clientHeight || 240;
    canvas.width = Math.round(cssW * dpr);
    canvas.height = Math.round(cssH * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, cssW, cssH);

    const css = getComputedStyle(canvas);
    const grid = css.getPropertyValue("--autd-grid") || "#5b5b66";
    const axis = css.getPropertyValue("--autd-axis") || "#9b9ba6";
    const accent = css.getPropertyValue("--autd-accent") || "#3b82f6";
    const dot = css.getPropertyValue("--autd-dot") || "#e5e7eb";

    const padL = 34;
    const padR = 8;
    const padT = 10;
    const padB = 18;
    const w = cssW - padL - padR;
    const h = cssH - padT - padB;
    const T = 1 / c.freq;
    const yOf = (v: number) => padT + h * (1 - v / 255);
    const xOf = (t: number) => padL + w * (t / T);

    ctx.strokeStyle = grid;
    ctx.lineWidth = 1;
    ctx.fillStyle = axis;
    ctx.font = "11px system-ui, sans-serif";
    ctx.textAlign = "right";
    ctx.textBaseline = "middle";
    for (const v of [0, 128, 255]) {
      ctx.beginPath();
      ctx.moveTo(padL, yOf(v));
      ctx.lineTo(padL + w, yOf(v));
      ctx.stroke();
      ctx.fillText(String(v), padL - 5, yOf(v));
    }

    const STEPS = 400;
    const line = (fn: (t: number) => number) => {
      ctx.beginPath();
      for (let i = 0; i <= STEPS; i++) {
        const t = (T * i) / STEPS;
        const x = xOf(t);
        const y = yOf(fn(t));
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();
    };

    const ref = refFn(c);
    if (ref) {
      ctx.strokeStyle = axis;
      ctx.globalAlpha = 0.4;
      ctx.lineWidth = 1.2;
      ctx.setLineDash([4, 4]);
      line(ref);
      ctx.setLineDash([]);
      ctx.globalAlpha = 1;
    }

    const value = valueFn(c);

    ctx.strokeStyle = accent;
    ctx.globalAlpha = 0.45;
    ctx.lineWidth = 1.5;
    line(value);
    ctx.globalAlpha = 1;

    const n = Math.max(2, Math.round(c.sampling / c.freq));
    ctx.fillStyle = dot;
    ctx.strokeStyle = dot;
    ctx.lineWidth = 1;
    let prev: [number, number] | null = null;
    for (let i = 0; i <= n; i++) {
      const t = (T * i) / n;
      const x = xOf(t);
      const y = yOf(value(t));
      if (prev) {
        ctx.globalAlpha = 0.5;
        ctx.beginPath();
        ctx.moveTo(prev[0], prev[1]);
        ctx.lineTo(x, y);
        ctx.stroke();
        ctx.globalAlpha = 1;
      }
      ctx.beginPath();
      ctx.arc(x, y, 2.2, 0, 2 * Math.PI);
      ctx.fill();
      prev = [x, y];
    }
  }

  function initOne(root: HTMLElement) {
    const cfg: Cfg = JSON.parse(root.dataset.config || "{}");
    const kind = cfg.kind || "sine";
    const canvas = root.querySelector(".autd-mod-canvas") as HTMLCanvasElement;
    const controls = root.querySelector(".autd-mod-controls") as HTMLElement;

    controls.querySelectorAll("label").forEach((l) => l.remove());

    (SPECS[kind] || []).forEach((s) => {
      const label = document.createElement("label");
      if (s.type === "toggle") {
        cfg[s.key] = s.def;
        label.classList.add("toggle");
        const input = document.createElement("input");
        input.type = "checkbox";
        input.checked = !!s.def;
        input.dataset.in = s.key;
        const name = document.createElement("span");
        name.className = "autd-mod-name";
        name.textContent = s.label;
        label.append(input, name);
      } else {
        const isSampling = s.key === "sampling";
        const min = isSampling ? cfg.freq * 2 : s.min!;
        const max = isSampling ? cfg.freq * 40 : s.max!;
        const step = isSampling ? cfg.freq : s.step!;
        const def = isSampling ? cfg.sampling : s.def;
        cfg[s.key] = def;
        const name = document.createElement("span");
        name.className = "autd-mod-name";
        name.textContent = s.label;
        const input = document.createElement("input");
        input.type = "range";
        input.min = String(min);
        input.max = String(max);
        input.step = String(step);
        input.value = String(def);
        input.dataset.in = s.key;
        const out = document.createElement("output");
        out.dataset.out = s.key;
        out.textContent = String(def);
        const val = document.createElement("span");
        val.className = "autd-mod-val";
        val.append(out, document.createTextNode(s.unit ? " " + s.unit : ""));
        label.append(name, input, val);
      }
      controls.appendChild(label);
    });

    const inputs = controls.querySelectorAll<HTMLInputElement>("input[data-in]");
    const sync = () => {
      inputs.forEach((inp) => {
        const key = inp.dataset.in!;
        if (inp.type === "checkbox") {
          cfg[key] = inp.checked ? 1 : 0;
        } else {
          cfg[key] = Number(inp.value);
          const o = controls.querySelector(`output[data-out="${key}"]`);
          if (o) o.textContent = inp.value;
        }
      });
      draw(canvas, cfg);
    };
    inputs.forEach((inp) => inp.addEventListener("input", sync));
    sync();
    new ResizeObserver(() => draw(canvas, cfg)).observe(canvas);
  }

  function initAll() {
    document
      .querySelectorAll<HTMLElement>(".autd-mod")
      .forEach((el) => initOne(el));
  }

  initAll();
  document.addEventListener("astro:page-load", initAll);
</script>

<style>
  .autd-mod {
    --autd-grid: var(--sl-color-gray-5);
    --autd-axis: var(--sl-color-gray-3);
    --autd-accent: var(--sl-color-accent);
    --autd-dot: var(--sl-color-white);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin: 1rem 0;
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 0.5rem;
    padding: 0.75rem;
    background: var(--sl-color-black);
  }
  .autd-mod-controls {
    order: 2;
    flex: 1 1 190px;
    min-width: 160px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .autd-mod-controls :global(label) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-2);
  }
  .autd-mod-controls :global(label.toggle) {
    flex-direction: row;
    align-items: center;
    gap: 0.4rem;
  }
  .autd-mod-controls :global(input[type="range"]) {
    width: 100%;
    margin: 0;
  }
  .autd-mod-controls :global(.autd-mod-val) {
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-white);
  }
  .autd-mod-name {
    font-family: var(--sl-font-mono, monospace);
  }
  .autd-mod-controls :global(.autd-mod-name) {
    font-family: var(--sl-font-mono, monospace);
  }
  .autd-mod-fixed {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    font-family: var(--sl-font-mono, monospace);
  }
  .autd-mod-canvas {
    flex: 2 1 300px;
    display: block;
    min-width: 0;
    width: 100%;
    height: 240px;
  }
</style>
